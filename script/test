#!/usr/bin/env bash
# Runs a Clang static analysis build (scan-build) over the project to detect
# potential bugs at compile time. Automatically detects the available version
# of scan-build installed in the environment.
set -euo pipefail

if command -v scan-build-10 >/dev/null 2>&1; then
  SCAN_BUILD=scan-build-10
elif command -v scan-build >/dev/null 2>&1; then
  SCAN_BUILD=scan-build
elif command -v scan-build-14 >/dev/null 2>&1; then
  SCAN_BUILD=scan-build-14
else
  echo "scan-build is not installed" >&2
  exit 1
fi

"$SCAN_BUILD" make
